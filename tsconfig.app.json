{
  "//": "TypeScript settings for our Vue app code (everything under src/).",
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.vue"],
  "compilerOptions": {
    "composite": true,
    "outDir": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "noEmit": true
  }
}
