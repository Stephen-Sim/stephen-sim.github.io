{
  "//": "TypeScript settings for Node-only build tooling (vite.config.ts, scripts/).",
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "types": ["node"],
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true
  },
  "include": ["vite.config.ts", "scripts/**/*.mjs"]
}
